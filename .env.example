# Database (Neon Postgres recommended)
# Use the pooled connection string from Neon dashboard. Omit channel_binding=require — it breaks Node on Windows.
# Local dev fallback: postgresql://user:pass@localhost:5432/syphus
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Wallet encryption (32-byte hex)
WALLET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Stellar (testnet default)
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Anchor orchestration
ANCHOR_PROVIDER=mock
COINSPH_TRANSFER_SERVER=https://coins.ph/api/v1/stellar
BCREMIT_TRANSFER_SERVER=https://api.bcremit.com/stellar

# Cron secret for indexer
CRON_SECRET=dev-cron-secret

# Soroban PaymentRegistry (PRD-F9) — build/deploy in WSL
SOROBAN_ENABLED=false
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Testnet deploy (verified 2026-07-12): CBFUNL6N4I6VFT6PRCG6BAUKNKGC4PFWHWGWKNVY5I6AKYW2CJLQD4AT
PAYMENT_REGISTRY_CONTRACT_ID=
SOROBAN_ADMIN_SECRET=

# Display-only PHP equivalent for dashboard (not a live FX rate)
PHP_REFERENCE_RATE=53
