{
  "name": "syphus",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @syphus/web dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @syphus/db generate",
    "db:migrate": "pnpm --filter @syphus/db migrate"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
